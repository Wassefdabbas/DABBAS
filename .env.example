# ── Cloudinary ─────────────────────────────────────────────────
# Three vars — all signed uploads. Cloud name + API key are exposed to
# the client via next.config.ts `env` block (no NEXT_PUBLIC_ prefix needed).
# API secret stays server-only and is consumed by /api/admin/cloudinary-sign.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── MongoDB ────────────────────────────────────────────────────
# Connection string. When unset the site falls back to hardcoded
# sample veils (admin writes are disabled).
MONGODB_URI=
# Database name. Defaults to "dabbas-atelier" when unset.
MONGODB_DB=dabbas-atelier

# ── Admin ──────────────────────────────────────────────────────
# Single hardcoded admin password. Set anything strong here.
ADMIN_PASSWORD=
# HMAC secret for the admin session cookie. Use a long random string
# (e.g. `openssl rand -hex 32`). Rotating invalidates all sessions.
SESSION_SECRET=
# Optional: session lifetime in hours. Defaults to 168 (7 days).
SESSION_TTL_HOURS=

# ── Public ─────────────────────────────────────────────────────
# Your real domain — used by sitemap.xml + OG metadata.
NEXT_PUBLIC_SITE_URL=
